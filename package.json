{
  "name": "iron-sci-fi",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:backend": "npm run dev --workspace @iron-sci-fi/backend",
    "dev:client": "npm run dev --workspace @iron-sci-fi/client",
